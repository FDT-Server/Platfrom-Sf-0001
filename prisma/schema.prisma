// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String   @id @default(uuid())
  email           String   @unique
  fullName        String
  password        String
  selectedRole    String
  otherRoleText   String?
  goals           String[]
  profileImage    String?
  collegeStudying String?  @default("")
  branch          String?  @default("")
  year            String?  @default("")
  dob             String?  @default("")
  portfolioLink   String?  @default("")
  linkedinLink    String?  @default("")
  about               String?  @default("")
  shareWithNetworking Boolean  @default(false)
  isPremium           Boolean  @default(false)
  otpCode             String?
  otpExpiry           DateTime?
  courseEnrollments CourseEnrollment[]
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model Message {
  id        String   @id @default(uuid())
  content   String
  userId    String
  fullName  String
  email     String
  role        String
  recipientId String?
  reactions   Json?    @default("{}")
  seenBy      Json?    @default("{}")
  createdAt   DateTime @default(now())
}

model StudyPod {
  id          String   @id @default(uuid())
  name        String
  creatorId   String
  creatorName String
  createdAt       DateTime @default(now())
  approvedUserIds Json?    @default("[]")
  waitingUserIds  Json?    @default("[]")
}

model StudyPodMessage {
  id          String   @id @default(uuid())
  studyPodId String
  content     String
  userId      String
  fullName    String
  email       String
  createdAt   DateTime @default(now())
}

model StudyPodTodo {
  id          String   @id @default(uuid())
  studyPodId String
  title       String
  completed   Boolean  @default(false)
  creatorName String
  createdAt   DateTime @default(now())
}

model StudyPodIdea {
  id          String   @id @default(uuid())
  studyPodId String
  title       String
  description String
  creatorName String
  createdAt   DateTime @default(now())
}

model PaymentRequest {
  id          String   @id @default(uuid())
  userId      String
  userName    String
  userEmail   String
  plan        String
  referenceNo String
  name        String
  utrNo       String
  status      String   @default("PENDING") // PENDING, APPROVED, REJECTED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Event {
  id             String   @id @default(uuid())
  title          String
  description    String
  day            String
  month          String
  time           String
  duration       String
  speakerName    String
  speakerTitle   String
  speakerCompany String
  speakerImage   String   @default("https://images.unsplash.com/photo-1534528741775-53994a69daeb?auto=format&fit=crop&q=80&w=120&h=120")
  category       String
  badgeBg        String   @default("bg-indigo-50 text-indigo-700 border-indigo-150")
  badgeText      String
  joinLink       String
  imageUrl       String?  @default("")
  createdAt      DateTime @default(now())
}

model Resource {
  id         String   @id @default(uuid())
  date       String
  publisher  String
  title      String
  category   String
  badgeColor String   @default("bg-indigo-50 text-indigo-700 border-indigo-100")
  headerBg   String   @default("bg-indigo-500 text-white")
  link       String
  imageUrl   String?  @default("")
  createdAt  DateTime @default(now())
}

model Course {
  id          String       @id @default(uuid())
  title       String
  description String
  duration    String?      @default("")
  instructor  String?      @default("")
  link        String?      @default("")
  imageUrl    String?      @default("")
  skillsGain  String?            @default("")
  outcomes    String?            @default("")
  price       Float?             @default(0.0)
  weeks       CourseWeek[]
  enrollments CourseEnrollment[]
  createdAt   DateTime           @default(now())
}

model CourseWeek {
  id          String   @id @default(uuid())
  courseId    String
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  weekNumber  Int
  title       String
  description String
  videoLink   String   @default("")
  createdAt   DateTime @default(now())
}

model Certificate {
  id          String   @id @default(uuid())
  title       String
  description String
  issuedBy    String?  @default("")
  link        String?  @default("")
  imageUrl    String?  @default("")
  createdAt   DateTime @default(now())
}

model CourseEnrollment {
  id          String   @id @default(uuid())
  courseId    String
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  phone       String
  email       String
  classLevel  String
  utrNo       String
  status      String   @default("PENDING") // PENDING, APPROVED, REJECTED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([courseId, userId])
}

model Opportunity {
  id           String   @id @default(uuid())
  title        String
  company      String
  location     String
  type         String   // e.g. Full-Time, Internship, Contract
  compensation String
  category     String
  description  String
  tags         String   // comma-separated
  link         String
  logoLetter   String   @default("")
  logoBg       String   @default("bg-slate-600 text-white")
  imageUrl     String?  @default("")
  createdAt    DateTime @default(now())
}

