generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  String             @id @default(uuid())
  email               String             @unique
  fullName            String
  password            String
  selectedRole        String
  otherRoleText       String?
  goals               String[]
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  branch              String?            @default("")
  collegeStudying     String?            @default("")
  dob                 String?            @default("")
  linkedinLink        String?            @default("")
  portfolioLink       String?            @default("")
  profileImage        String?
  year                String?            @default("")
  about               String?            @default("")
  otpCode             String?
  otpExpiry           DateTime?
  shareWithNetworking Boolean            @default(false)
  isPremium           Boolean            @default(false)
  courseEnrollments   CourseEnrollment[]
  Resume              Resume[]
}

model Message {
  id          String   @id @default(uuid())
  content     String
  userId      String
  fullName    String
  email       String
  role        String
  createdAt   DateTime @default(now())
  recipientId String?
  reactions   Json?    @default("{}")
  seenBy      Json?    @default("{}")
}

model StudyPod {
  id              String   @id @default(uuid())
  name            String
  creatorId       String
  creatorName     String
  createdAt       DateTime @default(now())
  approvedUserIds Json?    @default("[]")
  waitingUserIds  Json?    @default("[]")
}

model StudyPodMessage {
  id         String   @id @default(uuid())
  studyPodId String
  content    String
  userId     String
  fullName   String
  email      String
  createdAt  DateTime @default(now())
}

model StudyPodTodo {
  id          String   @id @default(uuid())
  studyPodId  String
  title       String
  completed   Boolean  @default(false)
  creatorName String
  createdAt   DateTime @default(now())
}

model StudyPodIdea {
  id          String   @id @default(uuid())
  studyPodId  String
  title       String
  description String
  creatorName String
  createdAt   DateTime @default(now())
}

model PaymentRequest {
  id          String   @id @default(uuid())
  userId      String
  userName    String
  userEmail   String
  plan        String
  referenceNo String
  name        String
  utrNo       String
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Event {
  id             String   @id @default(uuid())
  title          String
  description    String
  day            String
  month          String
  time           String
  duration       String
  speakerName    String
  speakerTitle   String
  speakerCompany String
  speakerImage   String   @default("https://images.unsplash.com/photo-1534528741775-53994a69daeb?auto=format&fit=crop&q=80&w=120&h=120")
  category       String
  badgeBg        String   @default("bg-indigo-50 text-indigo-700 border-indigo-150")
  badgeText      String
  joinLink       String
  createdAt      DateTime @default(now())
  imageUrl       String?  @default("")
}

model Resource {
  id         String   @id @default(uuid())
  date       String
  publisher  String
  title      String
  category   String
  badgeColor String   @default("bg-indigo-50 text-indigo-700 border-indigo-100")
  headerBg   String   @default("bg-indigo-500 text-white")
  link       String
  createdAt  DateTime @default(now())
  imageUrl   String?  @default("")
}

model Course {
  id          String             @id @default(uuid())
  title       String
  description String
  duration    String?            @default("")
  instructor  String?            @default("")
  link        String?            @default("")
  createdAt   DateTime           @default(now())
  imageUrl    String?            @default("")
  outcomes    String?            @default("")
  price       Float?             @default(0.0)
  skillsGain  String?            @default("")
  enrollments CourseEnrollment[]
  weeks       CourseWeek[]
}

model CourseWeek {
  id          String   @id @default(uuid())
  courseId    String
  weekNumber  Int
  title       String
  description String
  videoLink   String   @default("")
  createdAt   DateTime @default(now())
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

model Certificate {
  id          String   @id @default(uuid())
  title       String
  description String
  issuedBy    String?  @default("")
  link        String?  @default("")
  createdAt   DateTime @default(now())
  imageUrl    String?  @default("")
}

model CourseEnrollment {
  id         String   @id @default(uuid())
  courseId   String
  userId     String
  name       String
  phone      String
  email      String
  classLevel String
  utrNo      String
  status     String   @default("PENDING")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  course     Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([courseId, userId])
}

model Opportunity {
  id           String   @id @default(uuid())
  title        String
  company      String
  location     String
  type         String
  compensation String
  category     String
  description  String
  tags         String
  link         String
  logoLetter   String   @default("")
  logoBg       String   @default("bg-slate-600 text-white")
  imageUrl     String?  @default("")
  createdAt    DateTime @default(now())
}

model Resume {
  id             String   @id
  userId         String
  name           String
  template       String   @default("modern")
  status         String   @default("DRAFT")
  personalInfo   Json?    @default("{}")
  summary        String?  @default("")
  education      Json?    @default("[]")
  experience     Json?    @default("[]")
  projects       Json?    @default("[]")
  skills         Json?    @default("[]")
  certifications Json?    @default("[]")
  languages      Json?    @default("[]")
  interests      Json?    @default("[]")
  createdAt      DateTime @default(now())
  updatedAt      DateTime
  User           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Post {
  id          String   @id @default(uuid())
  title       String?  @default("")
  content     String
  category    String   @default("General")
  imageUrl    String?  @default("")
  tags        String?  @default("")
  userId      String
  userName    String
  userRole    String?  @default("")
  userImage   String?  @default("")
  likesCount  Int      @default(0)
  sharesCount Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

